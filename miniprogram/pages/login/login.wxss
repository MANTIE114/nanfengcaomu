/* miniprogram/pages/login/login.wxss */
.login-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background-color: #ffffff;
  padding: 120rpx 40rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.8;
}

.brand-name {
  font-family: 'Noto Serif SC', serif;
  font-size: 56rpx;
  font-weight: bold;
  color: #1e293b;
  letter-spacing: 0.1em;
  margin-bottom: 16rpx;
}

.brand-sub {
  font-size: 28rpx;
  color: #64748b;
  letter-spacing: 0.2em;
}

.login-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 80rpx; 
}

.btn-login {
  width: 100%;
  height: 96rpx;
  background-color: #b42222;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(180, 34, 34, 0.2);
  transition: all 0.2s;
}

.btn-login:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(180, 34, 34, 0.1);
}

.btn-loading {
  opacity: 0.7;
}

.agreement {
  margin-top: 48rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.link {
  color: #2d3e33;
}

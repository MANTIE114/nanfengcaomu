/* pages/payment_success/payment_success.wxss */
.page {
  background-color: #ffffff;
  min-height: 100vh;
  padding: 120rpx 40rpx;
  text-align: center;
}
.success-box {
  margin-bottom: 80rpx;
}
.icon-wrap {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background-color: rgba(180, 34, 34, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-img {
  width: 80rpx;
  height: 80rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1e293b;
}
.subtitle {
  font-size: 28rpx;
  color: #64748b;
  margin-top: 16rpx;
}

.action-btns {
  margin-top: 80rpx;
}
button::after { display: none; }
.btn-primary {
  background-color: #b42222;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  padding: 24rpx 0;
  line-height: 1;
  margin-bottom: 32rpx;
}
.btn-outline {
  background-color: transparent;
  color: #64748b;
  font-size: 28rpx;
  border: 1px solid #cbd5e1;
  border-radius: 48rpx;
  padding: 24rpx 0;
  line-height: 1;
}

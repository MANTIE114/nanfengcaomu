@import '../../app.wxss';

.container {
  background-color: #f8f6f6;
  min-height: 100vh;
}

/* ══ Hero Section ══ */
.hero-section {
  position: relative;
  height: 70vh;
  z-index: 1;
}

.hero-bg {
  transform: scale(1.1);
  filter: brightness(0.9);
}

.hero-overlay {
  background: linear-gradient(to top, #f8f6f6 0%, rgba(0,0,0,0.1) 40%, transparent 100%);
}

.hero-title {
  font-family: 'Noto Serif SC', serif;
  letter-spacing: 0.3em;
  text-shadow: 0 4rpx 20rpx rgba(0,0,0,0.3);
}

.brand-badge {
  letter-spacing: 0.6em;
  font-weight: 500;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.2);
}

.scroll-indicator view {
  box-shadow: 0 0 20rpx rgba(255,255,255,0.4);
}

/* ══ Chapter Styling ══ */
.chapter-wrap {
  position: relative;
  z-index: 10;
  padding-bottom: 100rpx;
}

.glass-card {
  box-shadow: 0 32rpx 80rpx -16rpx rgba(0, 0, 0, 0.08);
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.paragraph {
  text-align: justify;
  letter-spacing: 1rpx;
  color: #4b5563;
}

.paragraph.indent-8 {
  text-indent: 2em;
}

/* ══ Features ══ */
.feature-box {
  box-shadow: 0 16rpx 32rpx -8rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.3s ease;
}

.feature-box:active {
  transform: scale(0.98);
}

/* ══ Animations ══ */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in-up {
  animation: fadeInUp 1s ease-out forwards;
}

.delay-100 { animation-delay: 0.2s; }
.delay-200 { animation-delay: 0.4s; }
.delay-300 { animation-delay: 0.6s; }

.shadow-pulse {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 0 rgba(180, 34, 34, 0.4); }
  70% { box-shadow: 0 0 0 10rpx rgba(180, 34, 34, 0); }
  100% { box-shadow: 0 0 0 0 rgba(180, 34, 34, 0); }
}

/* ══ Footer Decoration ══ */
.divider-dot {
  margin: 4rpx auto;
}

.tracking-thicker {
  letter-spacing: 0.4em !important;
}

/* ══ Tailwind Utility Simulators ══ */
.grid { display: grid; }
.grid-cols-2 { grid-template-columns: repeat(2, 1fr); }
.gap-4 { gap: 32rpx; }
.backdrop-blur-xl { backdrop-filter: blur(24px); }
.backdrop-blur-md { backdrop-filter: blur(12px); }
.bg-white-95 { background-color: rgba(255, 255, 255, 0.95); }
.bg-white-10 { background-color: rgba(255, 255, 255, 0.1); }
.border-white-20 { border-color: rgba(255, 255, 255, 0.2); }
.text-white-60 { color: rgba(255, 255, 255, 0.6); }
.text-white-80 { color: rgba(255, 255, 255, 0.8); }
.leading-relaxed { line-height: 1.7; }
.indent-8 { text-indent: 56rpx; }

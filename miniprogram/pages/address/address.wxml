<!-- pages/address/address.wxml -->
<view class="page">
  <!-- Select mode hint -->
  <view class="select-hint" wx:if="{{selectMode}}">点击下方地址即可选用</view>

  <!-- Empty State -->
  <view class="empty" wx:if="{{addresses.length === 0}}">
    <image src="https://img.icons8.com/ios/80/b42222/home-address.png" class="empty-icon"></image>
    <view class="empty-text">尚无收件地址</view>
    <view class="empty-sub">添加一个地址，方便为您送达香品</view>
  </view>

  <!-- Address List -->
  <scroll-view scroll-y class="list" wx:if="{{addresses.length > 0}}">
    <view class="addr-card" wx:for="{{addresses}}" wx:key="id">
      <view class="card-body {{selectMode ? 'card-selectable' : ''}}" bindtap="editAddress" data-addr="{{item}}">
        <view class="card-top">
          <text class="recipient">{{item.recipient}}</text>
          <text class="phone">{{item.phone}}</text>
          <view class="default-tag" wx:if="{{item.is_default}}">默认</view>
        </view>
        <view class="addr-line">{{item.province}}{{item.city}}{{item.district}} {{item.detail}}</view>
      </view>
      <view class="card-actions">
        <view class="action-btn" bindtap="setDefault" data-id="{{item.id}}" wx:if="{{!item.is_default}}">
          <image src="https://img.icons8.com/ios/28/b42222/checkmark--v1.png" class="act-icon"></image>
          <text>设为默认</text>
        </view>
        <view class="action-btn edit-btn" bindtap="editAddress" data-addr="{{item}}">
          <image src="https://img.icons8.com/ios/28/64748b/edit--v1.png" class="act-icon"></image>
          <text>编辑</text>
        </view>
        <view class="action-btn delete-btn" bindtap="deleteAddress" data-id="{{item.id}}">
          <image src="https://img.icons8.com/ios/28/e53e3e/trash--v1.png" class="act-icon"></image>
          <text>删除</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- Add Button -->
  <view class="footer">
    <button class="btn-add" bindtap="addAddress">+ 新增收件地址</button>
  </view>

  <!-- Add / Edit Modal -->
  <view class="modal-mask" wx:if="{{showForm}}" bindtap="closeForm"></view>
  <view class="modal" wx:if="{{showForm}}">
    <view class="modal-title">{{editing ? '编辑地址' : '新增地址'}}</view>

    <!-- 国内/海外 切换 -->
    <view class="seg-ctrl">
      <view class="seg-item {{!form.isOverseas ? 'seg-active' : ''}}" bindtap="setDomestic">🇨🇳 中国大陆</view>
      <view class="seg-item {{form.isOverseas ? 'seg-active' : ''}}" bindtap="setOverseas">🌏 海外/港澳台</view>
    </view>

    <view class="form-group">
      <text class="label">收件人</text>
      <input class="input" placeholder="姓名" value="{{form.recipient}}" bindinput="onInput" data-field="recipient"/>
    </view>
    <view class="form-group">
      <text class="label">手机号</text>
      <input class="input" placeholder="手机号码" type="number" value="{{form.phone}}" bindinput="onInput" data-field="phone"/>
    </view>

    <!-- 国内：微信 region picker -->
    <view class="form-group" wx:if="{{!form.isOverseas}}">
      <text class="label">省 / 市 / 区</text>
      <picker mode="region" value="{{regionValue}}" bindchange="onRegionChange">
        <view class="picker-row">
          <text class="picker-text {{regionValue.length ? '' : 'picker-placeholder'}}">
            {{regionValue.length ? regionValue[0] + ' ' + regionValue[1] + ' ' + regionValue[2] : '点击选择省市区'}}
          </text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <button class="btn-map" bindtap="chooseLocation">📍 地图快速定位</button>
    </view>

    <!-- 海外：自由输入 -->
    <view class="form-group" wx:if="{{form.isOverseas}}">
      <text class="label">国家 / 地区</text>
      <input class="input" placeholder="Country / Region（如 Singapore）" value="{{form.province}}" bindinput="onInput" data-field="province"/>
    </view>
    <view class="form-group" wx:if="{{form.isOverseas}}">
      <text class="label">州 / 城市</text>
      <input class="input" placeholder="State / City" value="{{form.city}}" bindinput="onInput" data-field="city"/>
    </view>
    <view class="form-group" wx:if="{{form.isOverseas}}">
      <text class="label">区 / 邮编</text>
      <input class="input" placeholder="District / Postal Code" value="{{form.district}}" bindinput="onInput" data-field="district"/>
    </view>

    <view class="form-group">
      <text class="label">详细地址</text>
      <textarea class="textarea" placeholder="街道、楼号、门牌、单元等" value="{{form.detail}}" bindinput="onInput" data-field="detail"></textarea>
    </view>
    <view class="form-group switch-row">
      <text class="label">设为默认地址</text>
      <switch checked="{{form.is_default}}" bindchange="onSwitchDefault" color="#b42222"/>
    </view>

    <view class="modal-btns">
      <button class="modal-btn-cancel" bindtap="closeForm">取消</button>
      <button class="modal-btn-submit" bindtap="submitForm">保存地址</button>
    </view>
  </view>
</view>

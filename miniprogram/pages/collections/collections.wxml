<view class="page">
  <view class="header">
    <view class="title">我的珍藏</view>
  </view>

  <view class="content">
    <block wx:if="{{products && products.length > 0}}">
      <view class="product-grid">
        <block wx:for="{{products}}" wx:key="id">
          <view class="product-card" bindtap="goToDetail" data-id="{{item.id}}">
            <image class="cover" src="{{item.cover_image}}" mode="aspectFill" />
            <view class="info">
              <view class="name">{{item.name}}</view>
              <view class="subtitle" wx:if="{{item.subtitle}}">{{item.subtitle}}</view>
              <view class="price">¥{{item.price}}</view>
            </view>
          </view>
        </block>
      </view>
    </block>
    <view class="empty" wx:else>
      <text>暂无收藏</text>
    </view>
  </view>
</view>

.page {
  background-color: #f8f6f6;
  min-height: 100vh;
  box-sizing: border-box;
  font-family: 'Noto Serif SC', serif;
}

.header {
  padding: 32rpx 32rpx 16rpx 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1e293b;
  letter-spacing: 2rpx;
}

.content {
  padding: 16rpx 32rpx 32rpx 32rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-card {
  width: 48%;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
  position: relative;
  transition: transform 0.2s ease;
}

.product-card:active {
  transform: scale(0.98);
}

.cover {
  width: 100%;
  height: 340rpx;
  background-color: #f5f5f4;
}

.info {
  padding: 24rpx;
}

.name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1e293b;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.subtitle {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.price {
  font-size: 32rpx;
  color: #b42222;
  font-weight: bold;
  margin-top: 16rpx;
}

.unfavorite {
  position: absolute;
  top: 270rpx; /* Placed near the bottom-right of the 340rpx image */
  right: 16rpx;
  width: 64rpx;
  height: 64rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  padding: 0 !important;
  margin: 0 !important;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
  backdrop-filter: blur(10px);
  z-index: 20;
}

.unfavorite::after {
  display: none !important;
}

.unfavorite image {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  color: #94a3b8;
  font-size: 28rpx;
  letter-spacing: 2rpx;
}
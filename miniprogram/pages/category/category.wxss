@import '../../app.wxss';

.h-screen { height: 100vh; display: flex; }
.bg-white { background-color: #ffffff; }
.bg-background-light { background-color: #f8f6f6; }

.border-r { border-right: 2rpx solid transparent; }
.border-primary-5 { border-color: rgba(180, 34, 34, 0.05); }

.w-1-3 { width: 33.333333%; }
.w-2-3 { width: 66.666667%; }
.w-full { width: 100%; }

.h-full { height: 100%; box-sizing: border-box; }

.cat-item {
  padding: 48rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #64748b;
  position: relative;
  transition: all 0.3s;
}

.cat-item.active {
  color: #b42222;
  font-weight: bold;
  background-color: #f8f6f6;
}

.cat-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background-color: #b42222;
  border-radius: 0 8rpx 8rpx 0;
}

.p-4 { padding: 32rpx; box-sizing: border-box; }
.pb-24 { padding-bottom: 240rpx; }
.mb-4 { margin-bottom: 32rpx; }

.text-slate-400 { color: #94a3b8; }
.text-slate-800 { color: #1e293b; }
.uppercase { text-transform: uppercase; }

.cat-grid {
  display: flex;
  flex-direction: column;
}
.gap-4 { gap: 32rpx; }

.rounded-xl { border-radius: 24rpx; }
.rounded-lg { border-radius: 16rpx; }
.shadow-sm { box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03); }
.text-center { text-align: center; }

.item-img {
  height: 256rpx;
}

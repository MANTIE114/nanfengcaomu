<view class="container h-screen flex flex-col">
  <!-- Top Search Bar (Simplified) -->
  <view class="cat-header" bindtap="goToSearch">
    <view class="cat-search-box">
      <icon type="search" size="14" color="#94a3b8"></icon>
      <text class="placeholder">寻香访道...</text>
    </view>
  </view>

  <view class="main-split flex-1 flex overflow-hidden">
    <!-- Left Side Sidebar -->
    <scroll-view class="sidebar w-1-3 bg-white h-full border-r border-primary-5" scroll-y>
    <view 
      class="cat-item {{activeCategoryId === item.id ? 'active' : ''}}" 
      wx:for="{{categories}}" wx:key="id"
      bindtap="switchCategory" data-id="{{item.id}}">
      {{item.name}}
    </view>
  </scroll-view>

  <!-- Right Side Content -->
  <scroll-view class="content w-2-3 h-full bg-background-light p-4 pb-24" scroll-y>
    <view class="text-sm text-slate-400 tracking-widest uppercase mb-4">/ {{activeCategory.subtitle || 'Zen Aesthetics'}}</view>
    
    <!-- 禅意加载器 -->
    <view class="zen-loader-small" wx:if="{{isLoading}}">
      <view class="loader-dot"></view>
    </view>

    <!-- 空状态 -->
    <view class="empty-mini" wx:if="{{!isLoading && products.length === 0}}">
      <image class="empty-icon" src="https://img.icons8.com/ios/80/b42222/box.png"></image>
      <text class="empty-text">该分类暂无商品</text>
    </view>

    <view class="cat-grid gap-4" wx:if="{{!isLoading && products.length > 0}}">
      <view class="item-card bg-white p-4 rounded-xl text-center shadow-sm"
        wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="item-img w-full rounded-lg" src="{{item.cover_image}}" mode="aspectFill"></image>
        <view class="mt-2 text-sm font-bold text-slate-800">{{item.name}}</view>
        <view class="mt-1 text-primary text-xs font-bold">¥{{item.price}}</view>
      </view>
    </view>
  </scroll-view>
  </view>
</view>

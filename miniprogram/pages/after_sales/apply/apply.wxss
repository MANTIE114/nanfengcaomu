/* pages/after_sales/apply/apply.wxss */
.container {
  padding: 30rpx;
  background-color: #f8f6f6;
  min-height: 100vh;
}

.product-card {
  display: flex;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #f1f5f9;
}

.product-info {
  margin-left: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  font-size: 30rpx;
  color: #1e293b;
  font-weight: 600;
  line-height: 1.4;
}

.product-spec {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.product-price {
  font-size: 32rpx;
  color: #b42222;
  font-weight: bold;
  margin-top: 12rpx;
}

.section-title {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  margin-left: 10rpx;
}

.service-list {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.service-item {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.service-item:last-child {
  border-bottom: none;
}

.service-item:active {
  background-color: #fafafa;
}

.service-content {
  flex: 1;
}

.service-name {
  font-size: 32rpx;
  color: #1e293b;
  font-weight: 600;
}

.service-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}

.arrow {
  font-size: 40rpx;
  color: #cbd5e1;
  margin-left: 20rpx;
}

.footer-tip {
  position: absolute;
  bottom: 80rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 24rpx;
  color: #cbd5e1;
  letter-spacing: 2rpx;
  font-style: italic;
}

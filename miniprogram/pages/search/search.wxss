.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8f6f6;
}

.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #ffffff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-wrap {
  flex: 1;
  background-color: #f1f5f9;
  height: 72rpx;
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1e293b;
}

.cancel-btn {
  margin-left: 24rpx;
  font-size: 28rpx;
  color: #64748b;
}

.search-content {
  flex: 1;
  overflow: hidden;
}

.results-info {
  padding: 24rpx 32rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.product-grid {
  padding: 0 32rpx 32rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.product-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}

.product-img {
  width: 100%;
  height: 320rpx;
  background-color: #f1f5f9;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 26rpx;
  font-bold: bold;
  color: #1e293b;
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.product-subtitle {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-price {
  font-size: 26rpx;
  color: #b42222;
  font-weight: bold;
}

.view-btn {
  font-size: 20rpx;
  color: #b42222;
  border: 1rpx solid #b42222;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ══ Initial State ══ */
.initial-state {
  padding: 40rpx 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #475569;
  margin-bottom: 24rpx;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.tag {
  padding: 12rpx 32rpx;
  background-color: #ffffff;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #64748b;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02);
}

/* ══ Empty State ══ */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.1;
  margin-bottom: 40rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #475569;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #94a3b8;
}

/* ══ 禅意加载器 ══ */
.zen-loader-small {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}
.zen-loader-small .loader-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #b42222;
  border-radius: 50%;
  animation: zen-pulse 2s infinite ease-in-out;
}

@keyframes zen-pulse {
  0% { transform: scale(0.8); opacity: 0.2; }
  50% { transform: scale(2.5); opacity: 0.6; }
  100% { transform: scale(0.8); opacity: 0.2; }
}

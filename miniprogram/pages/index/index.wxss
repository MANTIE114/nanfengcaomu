.search-btn-float {
  position: absolute;
  top: 60rpx;
  left: 32rpx;
  width: 72rpx;
  height: 72rpx;
  background-color: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  box-shadow: none; /* removed shadow */
}

.banner {
  position: relative;
  height: 640rpx;
  width: 100%;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}
.banner-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, #f8f6f6, transparent);
}
.banner-content {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 48rpx;
  padding-bottom: 80rpx;
}
.banner-text-box {
  border-left: 4rpx solid #b42222;
  padding-left: 32rpx;
  display: flex;
  flex-direction: column;
}
.banner-title {
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4);
}
.banner-subtitle {
  color: #475569; /* 深灰色，在浅色背景上清晰可读 */
  text-shadow: none;
}

.categories {
  padding: 32rpx;
}
.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.grid-item {
  width: 48%;
  position: relative;
  aspect-ratio: 4 / 5;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: transparent; /* 与页面背景统一 */
  margin-bottom: 24rpx;
}
.grid-item.grid-hero {
  width: 100%;
  height: 400rpx;
  aspect-ratio: auto;
}
.grid-img {
  width: 100%;
  height: 100%;
  position: absolute;
}
.grid-overlay {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.2);
}
.grid-text {
  position: absolute;
  bottom: 0;
  left: 0;
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}
.grid-desc {
  font-size: 20rpx;
  text-transform: uppercase;
  margin-top: 8rpx;
}

.recommended {
  background-color: transparent;
  padding: 80rpx 32rpx;
  margin-top: 32rpx;
}
.divider {
  width: 64rpx;
  height: 2rpx;
  background-color: #b42222;
}

/* ══ Tabs ══ */
.tabs-scroll {
  width: 100%;
  white-space: nowrap;
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: #f8f6f6;
  padding: 24rpx 0;
  margin-left: -32rpx;
  padding-left: 32rpx;
  width: calc(100% + 64rpx);
}
.tabs-scroll::-webkit-scrollbar {
  display: none;
}
.tab-item-wrap {
  display: inline-flex;
  padding: 0 4rpx;
}
.category-tab {
  display: inline-block;
  padding: 16rpx 40rpx;
  font-size: 26rpx;
  color: #94a3b8;
  position: relative;
  transition: all 0.3s ease;
  letter-spacing: 0.05em;
}
.category-tab.active {
  color: #b42222;
  font-weight: bold;
}
.category-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 40rpx;
  right: 40rpx;
  height: 4rpx;
  background: #b42222;
  border-radius: 2rpx;
}

.product-item {
  background-color: transparent; /* 与页面背景统一 */
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: none; /* 去除阴影 */
  margin-bottom: 48rpx;
}

.product-image-wrap {
  position: relative;
  aspect-ratio: 16 / 9;
}
.product-image {
  width: 100%;
  height: 100%;
}
.product-tag {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  background-color: transparent; /* 去除标签层次 */
  color: #b42222; /* 使用品牌色文字 */
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  letter-spacing: 0.1em;
}
.product-info {
  padding: 48rpx;
  display: flex;
  flex-direction: column;
}
.product-desc {
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.5;
}
.btn-primary {
  background-color: #b42222;
  color: #fff;
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  margin-top: 32rpx;
}
.btn-outline {
  border: 2rpx solid #b42222;
  color: #b42222;
  background-color: transparent;
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  margin-top: 32rpx;
}

/* ══ Unified Empty State ══ */
.empty-state-wrap {
  width: 100%;
}
.empty-card {
  padding: 80rpx 0;
  background: transparent; /* Seamless blend */
}
.empty-art-img {
  border: 8rpx solid #fff;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.1);
}
.empty-media-wrap {
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
}

@keyframes ripple {
  0% { transform: scale(0.8); opacity: 0; }
  50% { transform: scale(1.1); opacity: 0.3; }
  100% { transform: scale(1.4); opacity: 0; }
}
.animate-ripple {
  animation: ripple 3s ease-out infinite;
}

.text-primary-40 {
  color: rgba(180, 34, 34, 0.4);
}



.banner {
  position: relative;
  height: 640rpx;
  width: 100%;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}
.banner-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, #f8f6f6, transparent);
}
.banner-content {
  position: relative;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 48rpx;
  padding-bottom: 80rpx;
}
.banner-text-box {
  border-left: 4rpx solid #b42222;
  padding-left: 32rpx;
  display: flex;
  flex-direction: column;
}

.categories {
  padding: 32rpx;
}
.grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.grid-item {
  width: 48%;
  position: relative;
  aspect-ratio: 4 / 5;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: rgba(180, 34, 34, 0.05);
  margin-bottom: 24rpx;
}
.grid-img {
  width: 100%;
  height: 100%;
  position: absolute;
}
.grid-overlay {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.2);
}
.grid-text {
  position: absolute;
  bottom: 0;
  left: 0;
  padding: 32rpx;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}
.grid-desc {
  font-size: 20rpx;
  text-transform: uppercase;
  margin-top: 8rpx;
}

.recommended {
  background-color: rgba(180, 34, 34, 0.05);
  padding: 80rpx 32rpx;
  margin-top: 32rpx;
}
.divider {
  width: 64rpx;
  height: 2rpx;
  background-color: #b42222;
}

.product-item {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
  margin-bottom: 48rpx;
}
.product-image-wrap {
  position: relative;
  aspect-ratio: 16 / 9;
}
.product-image {
  width: 100%;
  height: 100%;
}
.product-tag {
  position: absolute;
  top: 32rpx;
  left: 32rpx;
  background-color: rgba(180, 34, 34, 0.9);
  color: #fff;
  font-size: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  letter-spacing: 0.1em;
}
.product-info {
  padding: 48rpx;
  display: flex;
  flex-direction: column;
}
.product-desc {
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.5;
}
.btn-primary {
  background-color: #b42222;
  color: #fff;
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  margin-top: 32rpx;
}
.btn-outline {
  border: 2rpx solid #b42222;
  color: #b42222;
  background-color: transparent;
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
  text-align: center;
  margin-top: 32rpx;
}

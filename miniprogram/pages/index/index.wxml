    </view>
    <view class="grid">
      <view class="grid-item">
        <image class="grid-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuB3Quce4Byrq82Wa30RMoSyAZ27TZNtembxKFPWcBev_t5i6LS9eoI1ODhN-jJIiFuqO69MdUF_eeOdrvetmeRcaIl3F4F3NEu2oUCnm2UUhztr_eRMh-urLkVVXTwrR8oIkzt2s7UeO1gruYi9IA3gBPWFsRlskAMmrYm-E7MFZIJoxpy2PzxQ77JvfcMyOepbafPl-oxD2tPe-TQr3ULOvRG89fq-M3GUz6IV_NODsUWpGUxuFSl40xVsSSOunAInD_yrK0UsgDg" mode="aspectFill"></image>
        <view class="grid-overlay"></view>
        <view class="grid-text">
          <text class="grid-title text-base font-bold text-white">线香</text>
          <text class="grid-desc text-white">Stick Incense</text>
        </view>
      </view>
      <view class="grid-item">
        <image class="grid-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAsQE282vJcETqNCFJtUBVFI-2vdcfXSwG71dWi3HJr50pIv9AkABN2nVWSSh1ZFNQFU5XAO_KEdOBjFuw0ldihXVksr1HXgHxmmMaIpD-gvJHHA_iHiCUvLtDjbUczIZPCXKK1O7UOLsgdHdfI6edRuDuXdOo4OjcGTyKJApIyD0DPrNiegDMhILVp0KhY42bcJKgWy-84zjrBVr9h4gtdbtEs9oClzK_nloXK1b4awMNXho4yP3mRcheFwmA-rAgaumULLkgaWD0" mode="aspectFill"></image>
        <view class="grid-overlay"></view>
        <view class="grid-text">
          <text class="grid-title text-base font-bold text-white">香薰</text>
          <text class="grid-desc text-white">Aromatherapy</text>
        </view>
      </view>
      <view class="grid-item">
        <image class="grid-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDU_wRD-n8rplOIR3sVUaWdjfO5u6Frr4G7zPxHp9C7fkmaOWwNfd9AnnmyOLifXpG5RmWyNfulmsf93XqeobZj-kchv39Q8qeEmaowGAB7DHqeSN5Y5uerX9UheRDA1JGxfp_qsWq4yZWnZJM7iECK7KNC87IGSTkLOKVFPjQXFWAueWcY2-cwleyjxpLB-pEgRYOmUXW9U4xtwf9iWGwy700RKnZT2LDGGI6dMV_mCMiidPaDtHlJjuBoGu1pEMD7VqOIqs5bwjc" mode="aspectFill"></image>
        <view class="grid-overlay"></view>
        <view class="grid-text">
          <text class="grid-title text-base font-bold text-white">香珠香牌</text>
          <text class="grid-desc text-white">Incense Beads</text>
        </view>
      </view>
      <view class="grid-item">
        <image class="grid-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDwPC8OhhM23EIYvMUet7Nf6uDxi2KqGNAA6k4CBkHyGOCNPZZwOlyC-Uau21TpQtEhPYdTcBcPUnXpCFbs1A7ir9xKevELak7Z3EESZxcd-z-28qJW6scOX169BIn7HomHKf_ccZp3RoSZe7asnGTXa0SnV0HWAeubIhHZeK0ty9mpfx5sfAJPJfvCl8IogO9vSAiMnUUfFNFNdxz3giWM0qVDYtLlwlOtac40e6EeZEzKzm_gpfehl-tnmHZe7EY52A0rrM_XTlM" mode="aspectFill"></image>
        <view class="grid-overlay"></view>
        <view class="grid-text">
          <text class="grid-title text-base font-bold text-white">大漆珠</text>
          <text class="grid-desc text-white">Lacquer Beads</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Recommended Selection Section -->
  <view class="section recommended">
    <view class="text-center mb-8 flex flex-col items-center">
      <text class="text-2xl font-bold tracking-widest text-slate-800">古法匠心 · 南风草木</text>
      <text class="text-xs text-primary mt-2 uppercase tracking-widest">Zen Living Selection</text>
      <view class="divider mt-4"></view>
    </view>
    
    <view class="product-list">
      <view class="product-item" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="product-image-wrap">
          <image class="product-image" src="{{item.cover_image}}" mode="aspectFill"></image>
          <view class="product-tag" wx:if="{{item.category_id == 1}}">纯手工制作</view>
        </view>
        <view class="product-info">
          <view class="product-header flex justify-between items-start mb-2">
            <text class="text-lg font-bold">{{item.name}}</text>
            <text class="text-primary font-bold">¥{{item.price}}</text>
          </view>
          <text class="product-desc mb-4">{{item.description}}</text>
          <button class="btn-primary w-full">查看详情</button>
        </view>
      </view>
    </view>
  </view>
</view>

<view class="container">
  <!-- Search Overlay Button -->
  <view class="search-btn-float" bindtap="goToSearch">
    <icon type="search" size="18" color="white"></icon>
  </view>
  <!-- Banner Section -->
  <view class="banner">
    <image class="banner-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDaBP82_28p6mCz0TH1ErNHvcXhm2DvPoiRBfuzteat20yKt6JWrLVqnzYJpy7Xrx_rb9UESvQbvLtrLu-bNI9P7kwOz_hpoNiEZNGE8CSPNH5F_PAiHahrLm-UY0nDihP7gGpcBGV43NdNpwAyOrMwOBiTHUamFx7iQbZsjwPLaDmYjAUpSSRMoAywzvfi1PJearGuk3UT_Y1QEe54U_g9Vn3xcPTHTR0fx8UE4X0z0re4mAfoN6PpfU7T3HHXUhw95loDWwavyx0" mode="aspectFill"></image>
    <view class="banner-overlay"></view>
    <view class="banner-content">
      <view class="banner-text-box">
        <text class="banner-title text-3xl font-bold text-white">寻香访道</text>
        <text class="banner-subtitle text-sm mt-2 tracking-widest">The Essence of Tranquility</text>
      </view>
    </view>
  </view>

  <!-- Categories Section -->
  <view class="section categories">
    <view class="section-header flex items-center justify-between mb-6">
      <view class="section-title text-lg font-bold">
        <text class="text-primary mr-2">/</text>香材分类
      </view>
      <text class="section-subtitle text-xs text-primary uppercase tracking-widest">Categories</text>
    </view>
    <view class="grid">
      <view 
        class="grid-item {{topCategories.length % 2 !== 0 && index === 0 ? 'grid-hero' : ''}}" 
        wx:for="{{topCategories}}" 
        wx:key="id" 
        bindtap="goToCategoryPage" data-id="{{item.id}}"
      >
        <image class="grid-img" src="{{item.displayImage}}" mode="aspectFill"></image>
        <view class="grid-overlay"></view>
        <view class="grid-text">
          <text class="grid-title {{topCategories.length % 2 !== 0 && index === 0 ? 'text-2xl' : 'text-base'}} font-bold text-white">{{item.name}}</text>
          <text class="grid-desc text-white">{{item.subtitle || 'Zen Aesthetics'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Recommended Selection Section -->
  <view class="section recommended">
    <view class="text-center mb-6 flex flex-col items-center">
      <text class="text-2xl font-bold tracking-widest text-slate-800">古法匠心 · 南风草木</text>
      <text class="text-xs text-primary mt-2 uppercase tracking-widest">Zen Living Selection</text>
      <view class="divider mt-4"></view>
    </view>

    <!-- 分类 Tab -->
    <scroll-view scroll-x class="tabs-scroll mb-8" scroll-with-animation>
      <view class="tab-item-wrap">
        <view 
          class="category-tab {{selectedCategoryId === 0 ? 'active' : ''}}" 
          bindtap="selectCategory" data-id="{{0}}">
          全部
        </view>
        <view 
          class="category-tab {{selectedCategoryId === item.id ? 'active' : ''}}" 
          wx:for="{{categories}}" wx:key="id" 
          bindtap="selectCategory" data-id="{{item.id}}">
          {{item.name}}
        </view>
      </view>
    </scroll-view>
    
    <view class="product-list" wx:if="{{products && products.length > 0}}">
      <view class="product-item" wx:for="{{products}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="product-image-wrap">
          <image class="product-image" src="{{item.cover_image}}" mode="aspectFill"></image>
          <view class="product-tag" wx:if="{{item.category_id == 1}}">纯手工制作</view>
        </view>
        <view class="product-info">
          <view class="product-header flex justify-between items-start mb-2">
            <text class="text-lg font-bold">{{item.name}}</text>
            <text class="text-primary font-bold">¥{{item.price}}</text>
          </view>
          <text class="product-desc mb-4">{{item.subtitle || item.description || ''}}</text>
          <button class="btn-primary w-full">查看详情</button>
        </view>
      </view>
    </view>
    
    <!-- ══ Unified Empty State ══ -->
    <view class="empty-state-wrap pb-20" wx:else>
      <view class="empty-card flex flex-col items-center justify-center">
        <view class="empty-media-wrap mb-10 relative">
          <image src="https://images.unsplash.com/photo-1528459801416-a9e53bbf4e17?auto=format&fit=crop&q=80&w=400&h=400" mode="aspectFill" class="empty-art-img rounded-full w-48 h-48 opacity-80 shadow-inner-zen"></image>
          <view class="absolute inset-0 rounded-full border border-primary-10 animate-ripple"></view>
        </view>
        <view class="text-xl font-bold text-slate-800 mb-2 tracking-widest">雅物寻踪</view>
        <view class="text-xs text-primary-40 tracking-[0.4em] uppercase mb-8">Zen Collection Curating</view>
        <view class="w-12 h-px bg-primary opacity-20"></view>
        <view class="text-mini text-slate-400 mt-8 italic px-12 text-center leading-relaxed">
          <view>“好物如良友，相遇有时。”</view>
          <view class="mt-1">此处暂无存货，不妨移步他处寻香。</view>
        </view>
      </view>
    </view>
  </view>
</view>
